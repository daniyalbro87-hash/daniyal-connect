rules_version = '2';

// =============================================================
// Daniyal Chat — Firestore Security Rules
// Copy-paste directly into the Firebase console (Firestore → Rules).
// =============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function chatParticipants(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    function isChatMember(chatId) {
      return isSignedIn() && request.auth.uid in chatParticipants(chatId);
    }

    // ---------- users ----------
    match /users/{uid} {
      // Public read: needed for search & profile pages. Only non-sensitive fields are stored here.
      allow read: if isSignedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- invite codes ----------
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // ---------- chats + messages ----------
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      // On create: caller must be one of exactly-two participants
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      // On update: caller must be a member (of before or after state, to allow last-message writes)
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants
            || request.auth.uid in request.resource.data.participants);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.sender == request.auth.uid;
        // Only receiver can mark delivered/read; sender can edit own text.
        allow update: if isChatMember(chatId)
          && (request.auth.uid == resource.data.sender
              || request.auth.uid == resource.data.receiver);
        allow delete: if isChatMember(chatId)
          && request.auth.uid == resource.data.sender;
      }

      match /typing/{uid} {
        allow read: if isChatMember(chatId);
        allow write: if isChatMember(chatId) && request.auth.uid == uid;
      }
    }

    // ---------- friend requests ----------
    match /friendRequests/{reqId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.from
            || request.auth.uid == resource.data.to);
      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.from != request.resource.data.to
        && request.resource.data.status == 'pending';
      // Recipient can accept/decline; sender can cancel.
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.to
            || request.auth.uid == resource.data.from);
      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.to
            || request.auth.uid == resource.data.from);
    }

    // ---------- WebRTC calls ----------
    // Signaling doc:  calls/{callId}   = { caller, callee, status, offer, answer, callerProfile, callNonce, createdAt }
    // ICE candidates: calls/{callId}/offerCandidates/*   (caller's local candidates)
    //                 calls/{callId}/answerCandidates/*  (callee's local candidates)
    match /calls/{callId} {
      function isCaller() { return isSignedIn() && request.auth.uid == resource.data.caller; }
      function isCallee() { return isSignedIn() && request.auth.uid == resource.data.callee; }
      function isPartyIn(data) {
        return isSignedIn() && (request.auth.uid == data.caller || request.auth.uid == data.callee);
      }

      allow read: if isPartyIn(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.caller == request.auth.uid
        && request.resource.data.callee is string
        && request.resource.data.callee != request.auth.uid
        && request.resource.data.status == 'ringing';
      // Either party can update (answer, status transitions, ICE-restart offer).
      allow update: if isPartyIn(resource.data);
      // Either party can clean up ended docs; owner nonce-check is enforced client-side.
      allow delete: if isPartyIn(resource.data);

      match /offerCandidates/{cid} {
        allow read: if isPartyIn(get(/databases/$(database)/documents/calls/$(callId)).data);
        allow create: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.caller;
        allow delete: if isPartyIn(get(/databases/$(database)/documents/calls/$(callId)).data);
      }
      match /answerCandidates/{cid} {
        allow read: if isPartyIn(get(/databases/$(database)/documents/calls/$(callId)).data);
        allow create: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callee;
        allow delete: if isPartyIn(get(/databases/$(database)/documents/calls/$(callId)).data);
      }
    }

    // ---------- FCM device tokens (optional; per-user push tokens) ----------
    match /fcmTokens/{uid}/tokens/{tokenId} {
      allow read, write: if isSelf(uid);
    }

    // ---------- catch-all (deny) ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
